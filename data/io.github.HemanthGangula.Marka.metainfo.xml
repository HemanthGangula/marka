<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.HemanthGangula.Marka</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <name>Marka</name>
  <summary>Lightweight Markdown viewer and editor</summary>

  <developer id="io.github.HemanthGangula">
    <name>Hemanth</name>
  </developer>

  <description>
    <p>
      Marka is a lightweight, native Linux Markdown viewer and editor built
      with GTK4 and libadwaita. It renders Markdown in real time with
      GitHub-style typography, supports syntax-highlighted code blocks via
      Pygments, and respects the system light/dark theme automatically.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Live split-pane preview with GitHub-style CSS</li>
      <li>Syntax highlighting via GtkSourceView 5 or built-in fallback</li>
      <li>Tables, task lists, footnotes, fenced code, and all CommonMark extras</li>
      <li>Find in document (Ctrl+F)</li>
      <li>Zoom preview (Ctrl+= / Ctrl+-)</li>
      <li>Print preview (Ctrl+P)</li>
      <li>Export to HTML</li>
      <li>Drag-and-drop file opening</li>
      <li>Recent files history</li>
      <li>Persistent window geometry and last-opened file</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.HemanthGangula.Marka.desktop</launchable>

  <url type="homepage">https://github.com/HemanthGangula/marka</url>
  <url type="bugtracker">https://github.com/HemanthGangula/marka/issues</url>
  <url type="vcs-browser">https://github.com/HemanthGangula/marka</url>

  <releases>
    <release version="1.0.0" date="2026-03-27">
      <description>
        <p>Initial stable release with full GTK4/libadwaita integration.</p>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1"/>

