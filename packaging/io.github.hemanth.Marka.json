{
  "app-id": "io.github.hemanth.Marka",
  "runtime": "org.gnome.Platform",
  "runtime-version": "47",
  "sdk": "org.gnome.Sdk",
  "command": "marka",
  "finish-args": [
    "--socket=fallback-x11",
    "--socket=wayland",
    "--filesystem=xdg-documents",
    "--talk-name=org.gtk.vfs.*",
    "--filesystem=xdg-run/gvfsd"
  ],
  "modules": [
    {
      "name": "python3-markdown",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --no-index --find-links=\"file://${PWD}\" --prefix=${FLATPAK_DEST} Markdown"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/source/M/Markdown/Markdown-3.6.tar.gz",
          "sha256": "ed4f41f6daecbeeb96e576ce414c41d2d876daa9a16cb35fa8ed8c2ddfad0224"
        }
      ]
    },
    {
      "name": "python3-pygments",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --no-index --find-links=\"file://${PWD}\" --prefix=${FLATPAK_DEST} pygments"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/source/P/Pygments/pygments-2.18.0.tar.gz",
          "sha256": "786ff802f32e91311bff3889f6e9a86e81505fe99f2735bb6d60ae0c5004f199"
        }
      ]
    },
    {
      "name": "marka",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --no-index --prefix=${FLATPAK_DEST} .",
        "install -Dm644 data/io.github.hemanth.Marka.metainfo.xml ${FLATPAK_DEST}/share/metainfo/io.github.hemanth.Marka.metainfo.xml",
        "install -Dm644 marka.desktop ${FLATPAK_DEST}/share/applications/io.github.hemanth.Marka.desktop",
        "install -Dm644 data/icons/io.github.hemanth.Marka.svg ${FLATPAK_DEST}/share/icons/hicolor/scalable/apps/io.github.hemanth.Marka.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": ".."
        }
      ]
    }
  ]
}
